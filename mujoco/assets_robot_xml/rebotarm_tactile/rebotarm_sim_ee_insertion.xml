<!--    </sensor>-->

    <keyframe>
        <key qpos="0 0 0 0 0 0 0 0
                   0.2 0.5 0.05 1 0 0 0  -0.2 0.5 0.05 1 0 0 0"/>
    </keyframe>

</mujoco>

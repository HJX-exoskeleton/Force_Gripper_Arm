<mujoco>

    <include file="scene.xml"/>
<!--    <include file="reBot-DevArm_gripper.xml"/>-->
    <include file="reBot-DevArm_gripper_tactile.xml"/>

    <worldbody>

        <body name="peg" pos="0.2 0.5 0.05">
            <joint name="red_peg_joint" type="free" frictionloss="0.01" />
            <inertial pos="0 0 0" mass="1.5" diaginertia="0.002 0.002 0.002" />
            <geom condim="4" solimp="2 1 0.01" solref="0.01 1" friction="1 0.005 0.0001" pos="0 0 0" size="0.06 0.01 0.01" type="box" name="red_peg" rgba="1 0 0 1" />
        </body>

        <body name="socket" pos="-0.2 0.5 0.05" euler="0 1.57 0">
            <joint name="blue_socket_joint" type="free" frictionloss="0.01" />
            <inertial pos="0 0 0" mass="0.025" diaginertia="0.002 0.002 0.002" />
<!--            <geom condim="4" solimp="2 1 0.01" solref="0.01 1" friction="1 0.005 0.0001" pos="0 0 0" size="0.06 0.01 0.01" type="box" name="red_peg_ref" rgba="1 0 0 1" />-->
            <geom condim="4" solimp="2 1 0.01" solref="0.01 1" friction="1 0.05 0.001" pos="0 0 -0.02" size="0.06 0.018 0.002" type="box" name="socket-1" rgba="0 0 1 1" />
            <geom condim="4" solimp="2 1 0.01" solref="0.01 1" friction="1 0.05 0.001" pos="0 0 0.02" size="0.06 0.018 0.002" type="box" name="socket-2" rgba="0 0 1 1" />
            <geom condim="4" solimp="2 1 0.01" solref="0.01 1" friction="1 0.05 0.001" pos="0 0.02 0" size="0.06 0.002 0.018" type="box" name="socket-3" rgba="0 0 1 1" />
            <geom condim="4" solimp="2 1 0.01" solref="0.01 1" friction="1 0.05 0.001" pos="0 -0.02 0" size="0.06 0.002 0.018" type="box" name="socket-4" rgba="0 0 1 1" />
            <geom condim="4" solimp="2 1 0.01" solref="0.01 1" friction="1 0.005 0.0001" pos="0 0 0" size="0.04 0.01 0.01" type="box" name="pin" rgba="1 0 0 1" />
        </body>

        <body name="hathpace" pos="0.2 0.6 0.1">
            <inertial pos="0 0 0" mass="0.1" diaginertia="0.002 0.002 0.002" />
            <geom condim="4" solimp="2 1 0.01" solref="0.01 1" friction="1 0.005 0.0001" pos="0 0 0" size="0.06 0.06 0.01" type="box" material="marble" />
            <body name="support_cylinder" pos="0 0.0 -0.055">
                <geom condim="4" material="marble" type="cylinder" size="0.025 0.045"/>
            </body>
        </body>

    </worldbody>

    <actuator>
        <position ctrllimited="true" ctrlrange="-1.87 1.87" joint="joint1" kp="800"  user="1" forcelimited="true" forcerange="-150 150"/>
        <position ctrllimited="true" ctrlrange="-3.14 0" joint="joint2" kp="800"  user="1" forcelimited="true" forcerange="-150 150"/>
        <position ctrllimited="true" ctrlrange="-3.14 0" joint="joint3" kp="800"  user="1" forcelimited="true" forcerange="-150 150"/>
        <position ctrllimited="true" ctrlrange="-1.87 1.57" joint="joint4" kp="600"  user="1" forcelimited="true" forcerange="-100 100"/>
        <position ctrllimited="true" ctrlrange="-1.57 1.57" joint="joint5" kp="600"  user="1" forcelimited="true" forcerange="-100 100"/>
        <position ctrllimited="true" ctrlrange="-3.14 3.14" joint="joint6" kp="600" user="1" forcelimited="true" forcerange="-100 100"/>

        <position class="finger" name="gripper" joint="left_finger" user="1" forcelimited="true" forcerange="-100 100"/>
    </actuator>


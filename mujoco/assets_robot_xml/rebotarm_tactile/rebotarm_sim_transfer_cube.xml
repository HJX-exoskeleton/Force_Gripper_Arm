        <body name="target_box" pos="0.0 0.4 0.05">
            <geom condim="4" solimp="2 1 0.01" solref="0.01 1" friction="1 0.005 0.0001" pos="0 0 0" size="0.1 0.08 0.02" type="box" name="target_box" rgba="0.3 0.4 0.7 0.8" />

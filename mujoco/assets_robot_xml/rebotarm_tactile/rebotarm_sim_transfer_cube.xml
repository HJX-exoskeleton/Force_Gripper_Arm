        <position ctrllimited="true" ctrlrange="-1.57 1.57" joint="joint5" kp="600"  user="1" forcelimited="true" forcerange="-100 100"/>
        <position ctrllimited="true" ctrlrange="-3.14 3.14" joint="joint6" kp="600" user="1" forcelimited="true" forcerange="-100 100"/>

        <position class="finger" name="gripper" joint="left_finger" user="1" forcelimited="true" forcerange="-100 100"/>
    </actuator>

